@Comment{
  ここから下は，BibTeXの記述例です。
  以下の文献は，引用方法を説明するために作成した架空の資料です。
}

@Comment{
  学術雑誌に掲載された論文の例
}
@article{sample_article,
  author  = {{慎 祥揆} and {笠原 秀星}},
  title   = {LaTeXによる学術文書作成の基礎},
  journal = {文書作成演習論文誌},
  year    = {2026},
  volume  = {1},
  number  = {1},
  pages   = {1--10}
}

@Comment{
  書籍の例
}
@book{sample_book,
  author    = {{慎 祥揆}},
  title     = {はじめてのLaTeX},
  publisher = {文書作成出版},
  year      = {2026},
  address   = {東京}
}

@Comment{
  学会予稿集に収録された論文の例
}
@inproceedings{sample_conference_paper,
  author    = {{慎 祥揆}},
  title     = {LaTeXを用いた卒業論文作成支援},
  booktitle = {文書作成技術研究会予稿集},
  year      = {2026},
  pages     = {20--25}
}

@Comment{
  修士論文の例
}
@mastersthesis{sample_master_thesis,
  author = {{慎 祥揆}},
  title  = {学術文書作成支援システムに関する研究},
  school = {東海大学大学院},
  year   = {2026}
}

@Comment{
  技術報告書の例
}
@techreport{sample_technical_report,
  author      = {{慎研究室}},
  title       = {LaTeX利用環境の動作確認報告書},
  institution = {東海大学},
  year        = {2026},
  number      = {TR-2026-01}
}

@Comment{
  Webページなど，ほかの種類に分類しにくい資料の例
}
@misc{sample_webpage,
  author       = {{文書作成学習サイト}},
  title        = {LaTeXの基本的な使い方},
  year         = {2026},
  howpublished = {\url{https://example.com/latex-guide}},
